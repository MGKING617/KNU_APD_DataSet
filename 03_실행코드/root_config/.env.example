# Shared deployment values
APP_ENV=production

# Frontend
# Leave empty when the frontend and API share the same origin through Nginx /api proxy.
VITE_API_BASE_URL=
VITE_DEV_API_PROXY_TARGET=http://localhost:8080

# Spring Boot API
SERVER_PORT=8080
CORS_ORIGIN=https://your-frontend-domain.example
DB_URL=jdbc:mysql://your-db-host:3306/youth_mental_health?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=your-db-user
DB_PASSWORD=replace-me
MYSQL_ROOT_PASSWORD=replace-me-root
ML_API_URL=http://localhost:8000

# LLM provider
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace-me
LLM_MODEL=openrouter/free
LLM_PROMPT_VERSION=v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Semantic cache
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_REDIS_URL=redis://localhost:6379/0
SEMANTIC_CACHE_ALLOWED_PURPOSES=GENERAL_GUIDANCE,FAQ
SEMANTIC_CACHE_BACKEND=redis
SEMANTIC_CACHE_NAMESPACE=youth-depression-llm:semantic-cache:v1
SEMANTIC_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_EMBEDDING_MODEL=intfloat/multilingual-e5-small
SEMANTIC_CACHE_PRELOAD_EMBEDDING=false
